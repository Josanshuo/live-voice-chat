# Copy to .env and fill in your OpenAI API key
OPENAI_API_KEY=sk-...

# xAI key，启用 Grok Voice Agent 后端时需要
# XAI_API_KEY=xai-...
# XAI_BASE_URL=https://api.x.ai

# Optional: custom API base URL (default: https://api.openai.com)
# OPENAI_BASE_URL=https://api.openai.com

# Optional: token service port (default: 8787, must match the proxy in vite.config.ts)
# TOKEN_SERVER_PORT=8787

# Optional: mount the app under a URL sub-path, e.g. behind a reverse proxy
# at https://example.com/voice/ (default: served at the root "/")
# BASE_PATH=/voice

# --- Login gate (off by default) ---
# Require a valid login before serving the app, by verifying a JWT session
# cookie issued by another app on the SAME domain (e.g. deployed as a
# sub-path behind the same reverse proxy). Works with any app that issues an
# HMAC-signed JWT cookie; LibreChat is one example.
# REQUIRE_AUTH=true

# The JWT signing secret of the app whose login cookie is verified
# (for LibreChat: the JWT_REFRESH_SECRET value from its .env).
# Required when REQUIRE_AUTH=true.
# AUTH_JWT_SECRET=...

# Name of the session cookie to verify (default: refreshToken, which is
# what LibreChat uses).
# AUTH_COOKIE_NAME=refreshToken

# Where to send browsers that are not logged in (default: /login)
# LOGIN_REDIRECT_URL=https://chat.example.com/login
